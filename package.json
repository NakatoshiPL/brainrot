{
  "name": "brainrots-trade-calculator",
  "private": true,
  "scripts": {
    "backend": "node backend/server.js",
    "frontend": "npm run dev --prefix frontend",
    "dev": "npm run frontend",
    "dev:all": "concurrently -k -n backend,frontend -c cyan,magenta \"npm run backend\" \"npm run frontend\"",
    "update-values": "node scripts/update-values.js",
    "detect-new": "node scripts/detect-new-brainrots.js",
    "add-wiki-items": "node scripts/add-more-items-from-wiki.js",
    "strip-no-thumb-brainrots": "node scripts/remove-no-thumb-brainrots.js",
    "fill-etfb-images": "node scripts/fetch-etfb-images.js --fill-only",
    "fill-wiki-search-images": "node scripts/fill-missing-images-wiki-search.js",
    "prefer-playbrainrot": "node scripts/fix-image-mapping.js --replace && node -e \"const fs=require('fs'); fs.copyFileSync('data/image-mapping.json','backend/data/image-mapping.json'); fs.copyFileSync('data/image-mapping.json','frontend/public/image-mapping.json');\"",
    "fill-beebom-images": "node scripts/fetch-beebom-images.js --beebom-only && node scripts/fetch-etfb-images.js --fill-only",
    "rebuild-images": "npm run fill-beebom-images",
    "fill-empty-images": "node scripts/fill-empty-wiki-images.js",
    "sync-data": "node scripts/sync-brainrots-data.js",
    "cache-thumbnails": "node scripts/cache-local-thumbnails.js",
    "fill-ui-sources": "node scripts/fill-images-from-ui-sources.js",
    "fill-ui-sources-tba": "node scripts/fill-images-from-ui-sources.js --allow-tba"
  },
  "devDependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "openai": "^6.31.0"
  }
}
