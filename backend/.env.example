OPENAI_API_KEY=sk-...
PORT=3001

# Dodatkowe originy CORS (po przecinku), np. preview Vercela
# ALLOWED_ORIGINS=https://twoj-projekt-git-main.vercel.app

# Periodic data refresh (long-running backend only; not for serverless)
# AUTO_UPDATE_ENABLED=1
# AUTO_UPDATE_TIMEZONE=UTC
# Daily income scrape (shigjeta) + sync to backend/public — default 05:00 UTC
# AUTO_UPDATE_VALUES_CRON=0 5 * * *
# Weekly wiki check for new brainrots (uses OpenAI for estimates) — default Sun 06:00 UTC
# AUTO_UPDATE_DETECT_CRON=0 6 * * 0
# Optional: run values pipeline once when server starts (dev only)
# AUTO_UPDATE_ON_START=0
